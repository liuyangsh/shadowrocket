#!name=CamScanner 解锁
#!desc=扫描全能王解锁
#!author=自用

[MITM]
hostname = *.camscanner.com, *.intsig.net

[Script]
CamScanner = type=http-response,pattern=^https:\/\/.*\.(intsig\.net|camscanner\.com),requires-body=1,max-size=-1,script-path=https://raw.githubusercontent.com/chxm1023/Rewrite/main/CamScanner.js
